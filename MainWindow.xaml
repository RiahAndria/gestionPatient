<Window x:Class="Patients.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:patient="clr-namespace:Patients.Views.Patient"
        xmlns:medecin="clr-namespace:Patients.Views.Medecin"
        xmlns:dossier="clr-namespace:Patients.Views.DossierMedical"
        xmlns:historique="clr-namespace:Patients.Views.Historique"
        xmlns:rendezvous="clr-namespace:Patients.Views.RendezVous"
        Title="Gestion Médicale" Height="800" Width="1000">

    <Grid Background="#F3F4F6">
        <TabControl Margin="15" Background="Transparent" BorderThickness="0">
            
            <TabItem Header="Patients" FontSize="14" FontWeight="SemiBold">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,10,0,0">
                        <patient:PatientFormView x:Name="PatientForm"/>
                        
                        <Border Background="White" CornerRadius="8" Margin="0,20,0,20" Padding="15">
                            <StackPanel>
                                <TextBlock Text="Liste des Patients" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="txtRecherche" Grid.Column="0" Height="32" Padding="6" 
                                             VerticalContentAlignment="Center" Tag="Rechercher par matricule, nom ou prénom..."/>
                                    <Button Content="Rechercher" Grid.Column="1" Width="100" Margin="10,0,0,0" 
                                            Click="btnRecherche_Click" Background="#4B5563" Foreground="White"/>
                                </Grid>

                                <DataGrid x:Name="dgPatients" AutoGenerateColumns="False" IsReadOnly="True" 
                                          MouseDoubleClick="dgPatients_MouseDoubleClick" Height="300">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Matricule" Binding="{Binding NumeroDossier}" Width="120"/>
                                        <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                                        <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*"/>
                                        <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="150"/>
                                        <DataGridTextColumn Header="Âge" Binding="{Binding DateNaissance}" Width="150"/> 
                                        </DataGrid.Columns>
                                </DataGrid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            
            <TabItem Header="Médecins" FontSize="14" FontWeight="SemiBold">
                <medecin:MedecinFormView Margin="0,10,0,0"/>
            </TabItem>
            <TabItem Header="Dossiers" FontSize="14" FontWeight="SemiBold">
                <dossier:DossierView Margin="0,10,0,0"/>
            </TabItem>
            <TabItem Header="Historique" FontSize="14" FontWeight="SemiBold">
                <historique:HistoriqueView Margin="0,10,0,0"/>
            </TabItem>
            <TabItem Header="Rendez-vous" FontSize="14" FontWeight="SemiBold">
                <rendezvous:RendezVousView Margin="0,10,0,0"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>