<Window x:Class="Patients.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Patients.Views"
        Title="Gestion des patients" Height="700" Width="900">

    <Grid Background="#F3F4F6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="20,15,20,10" Background="Transparent" BorderThickness="0" MaxWidth="500">
            <TabItem Header="Patient" FontSize="14" FontWeight="SemiBold">
                <views:PatientFormView Margin="0,10,0,0"/>
            </TabItem>
            
            <TabItem Header="Médecin" FontSize="14" FontWeight="SemiBold">
                <views:MedecinFormView Margin="0,10,0,0"/>
            </TabItem>

            <TabItem Header="Dossier" FontSize="14" FontWeight="SemiBold">
                <views:DossierView Margin="0,10,0,0"/>
            </TabItem>

            <TabItem Header="Historique" FontSize="14" FontWeight="SemiBold">
                <views:HistoriqueView Margin="0,10,0,0"/>
            </TabItem>

            <TabItem Header="Rendez-vous" FontSize="14" FontWeight="SemiBold">
                <views:RendezVousView Margin="0,10,0,0"/>
            </TabItem>

        </TabControl>

        <Border Grid.Row="1" Background="White" CornerRadius="8" Margin="20,0,20,20" Padding="15">
            <DataGrid x:Name="dgPersonnes" AutoGenerateColumns="False" IsReadOnly="True">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                    <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                    <DataGridTextColumn Header="Prénom" Binding="{Binding Prenom}" Width="*"/>
                    <DataGridTextColumn Header="Date de Naissance" Binding="{Binding DateNaissance, StringFormat=dd/MM/yyyy}" Width="140"/>
                    <DataGridTextColumn Header="Genre" Binding="{Binding Genre}" Width="100"/>
                    <DataGridTextColumn Header="Rôle" Binding="{Binding Role}" Width="100"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>