<Window x:Class="Patients.DetailPatientWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dossier Complet du Patient" Height="450" Width="500" WindowStartupLocation="CenterScreen">
    
    <Grid Background="#F9FAFB"> 
        
        <StackPanel Margin="20"> 
            <TextBlock Text="Informations" FontSize="20" FontWeight="Bold" Foreground="#1E3A8A" Margin="0,0,0,15"/>
            
            <Border BorderBrush="#E5E7EB" BorderThickness="1" Background="White" CornerRadius="6" Padding="15">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Matricule :" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock x:Name="lblMatricule" Grid.Row="0" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Nom &amp; Prénom :" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock x:Name="lblIdentite" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Contact :" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock x:Name="lblContact" Grid.Row="2" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Assurance :" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock x:Name="lblAssurance" Grid.Row="3" Grid.Column="1" Margin="0,5"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Médecin Traitant :" FontWeight="Bold" Margin="0,5"/>
                    <TextBlock x:Name="lblMedecin" Grid.Row="4" Grid.Column="1" Margin="0,5"/>
                </Grid>
            </Border>
            
            <Button Content="Fermer" Width="100" Height="30" Margin="0,20,0,0" HorizontalAlignment="Right" Click="BtnFermer_Click"/>
        </StackPanel>
    </Grid>
</Window>